// Prisma 스키마 파일
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Canvas {
  id        String   @id @default(uuid())
  yjsData   Bytes?   // Y.js 문서 전체 상태를 바이너리로 저장
  createdAt DateTime @default(now())

  @@map("canvases")
}
